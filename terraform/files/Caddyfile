# Removed: SMTP layer4 proxy (:25 → windmill_server:2525)
# Azure blocks outbound port 25 by default. Use external relay on 587 if email is needed.
# See: https://learn.microsoft.com/en-us/azure/virtual-network/troubleshoot-outbound-smtp-connectivity
# {
#     layer4 {
#         :25 {
#             proxy {
#                 to windmill_server:2525
#             }
#         }
#     }
# }

{$BASE_URL} {

        # Use Caddy's internal CA (self-signed) instead of public ACME. The NSG
        # only allows our own IP on 443, so Let's Encrypt can't reach the box to
        # validate a challenge; public ACME would fail and serve no cert at all.
        # Browser shows a one-time "untrusted issuer" warning — expected.
        tls internal

        # Extra services: LSP, Multiplayer, Debugger (windmill_extra gateway)
        reverse_proxy /ws/* /ws_mp/* /ws_debug/* http://windmill_extra:3000

        # Search indexer, Enterprise Edition (windmill_indexer:8002)
        # reverse_proxy /api/srch/* http://windmill_indexer:8002

        # Default: Windmill server
        reverse_proxy /* http://windmill_server:8000

        # TLS with custom certificates — uncomment for Phase 3 (internal cert, no public ACME path)
        # tls /certs/cert.pem /certs/key.pem
}
